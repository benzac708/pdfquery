# Get your free Groq API key: https://console.groq.com
GROQ_API_KEY=

# Get your free Cohere API key: https://dashboard.cohere.com
COHERE_API_KEY=

# Embedding provider: "cohere" or "local" (sentence-transformers, no key needed)
# EMBEDDING_PROVIDER removed — Cohere is now the only option

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
